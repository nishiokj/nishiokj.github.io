---
import BaseLayout from "../../layouts/BaseLayout.astro";
import site from "../../data/site.json";
import { assetPath, formatProjectDate, renderCode, renderProseBlocks } from "../../lib/render";

export function getStaticPaths() {
  return site.projects
    .filter((project) => project.slug)
    .map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
}

const { project } = Astro.props;
const detail = project.detail || {};
const title = `${project.title} - ${site.name}`;
const hasWhat = detail.what && (detail.what.intro?.length > 0 || detail.what.yaml || detail.what.diagram);
const defaultSampleIndex = detail.samples
  ? Math.max(0, detail.samples.findIndex((sample) => sample.language === "py"))
  : 0;
const githubLink = detail.artifacts?.find((artifact) => /github\.com/i.test(artifact.href));
---

<BaseLayout title={title} description={project.body} mainClass="project-detail-main">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-current="page">{project.title}</li>
    </ol>
  </nav>

  <header class="project-detail-header">
    <h1>{project.title}</h1>
  </header>

  <p class="project-lede">{project.body}</p>
  {project.stack?.length > 0 && (
    <ul class="project-stack project-detail-stack">
      {project.stack.map((item) => <li>{item}</li>)}
    </ul>
  )}
  <div class="project-detail-meta">
    <time class="project-detail-date" datetime={project.datetime}>{formatProjectDate(project.datetime, project.date, "long")}</time>
    {githubLink && (
      <a class="project-detail-github" href={githubLink.href} target="_blank" rel="noopener">
        <img src="/icons/github-icon.png" alt="" aria-hidden="true" />
        <span>{githubLink.label.replace(/^Source on /i, "")}</span>
      </a>
    )}
  </div>

  {hasWhat && (
    <>
      <hr class="rule" />
      <section>
        {detail.what.label !== "" && detail.what.label !== false && (
          <h2 class="section-label">{detail.what.label || "What it is"}</h2>
        )}
        {detail.what.intro?.length > 0 && (
          <div class="prose-blocks"><Fragment set:html={renderProseBlocks(detail.what.intro)} /></div>
        )}
        {(detail.what.yaml || detail.what.diagram) && (
          detail.what.yaml ? (
            <div class="what-figure-row">
              <pre class="arch-yaml"><code>{detail.what.yaml}</code></pre>
              {detail.what.diagram && (
                <figure class="chart">
                  <img src={assetPath(detail.what.diagram.src)} alt={detail.what.diagram.alt || "Architecture diagram"} />
                  {detail.what.diagram.caption && <figcaption class="chart-caption">{detail.what.diagram.caption}</figcaption>}
                </figure>
              )}
            </div>
          ) : (
            <div class="arch-diagram">
              <figure class="chart">
                <img src={assetPath(detail.what.diagram.src)} alt={detail.what.diagram.alt || "Architecture diagram"} />
                {detail.what.diagram.caption && <figcaption class="chart-caption">{detail.what.diagram.caption}</figcaption>}
              </figure>
            </div>
          )
        )}
      </section>
    </>
  )}

  {detail.why?.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">Why I built this</h2>
        <div class="prose-blocks" set:html={renderProseBlocks(detail.why)} />
      </section>
    </>
  )}

  {detail.decisions?.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">Decisions</h2>
        <div class="decisions-list">
          {detail.decisions.map((decision, index) => (
            <div class="decision-item">
              <span class="decision-num">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3 class="decision-heading">{decision.heading}</h3>
                <p class="decision-body">{decision.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  {detail.demo && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">{detail.demoLabel || "Demo"}</h2>
        <div>
          <div class="demo-grid">
            {(Array.isArray(detail.demo) ? detail.demo : [detail.demo]).map((demo) => (
              <div class="demo-tile">
                {demo.type === "video" ? (
                  <video src={assetPath(demo.src)} controls class="demo-media"></video>
                ) : (
                  <img src={assetPath(demo.src)} alt={demo.alt || "Demo"} class="demo-media" />
                )}
                {demo.note && <p class="demo-note">{demo.note}</p>}
              </div>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  {detail.samples?.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">{detail.samplesLabel || "Samples"}</h2>
        <div class="samples-list">
          <div class="sample-tabs" role="tablist">
            {detail.samples.map((sample, index) => (
              <button class:list={["sample-tab", { "is-active": index === defaultSampleIndex }]} type="button" data-sample-tab={index}>
                {sample.language === "py" ? "Python" : sample.language === "ts" ? "TypeScript" : sample.language}
              </button>
            ))}
          </div>
          <div class="sample-panels">
            {detail.samples.map((sample, index) => (
              <pre class="sample-code" hidden={index !== defaultSampleIndex} data-sample-panel={index}><code set:html={renderCode(sample.code, sample.language)} /></pre>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  {detail.experiments?.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">Experiments</h2>
        <div class:list={["grid-3", "experiments-grid", { "experiments-grid--multi": detail.experiments.length > 1 }]}>
          {detail.experiments.map((experiment) => (
            <figure class="chart">
              <img src={assetPath(experiment.src)} alt={experiment.alt} />
              <figcaption class="chart-caption">{experiment.alt}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    </>
  )}

  {detail.otherExperiments?.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">Other Experiments I've run</h2>
        <div class="prose-blocks" set:html={renderProseBlocks(detail.otherExperiments)} />
      </section>
    </>
  )}

  {detail.performance?.rows?.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <h2 class="section-label">{detail.performance.label || "Performance"}</h2>
        <div class="performance-table-wrap">
          <table class="performance-table">
            <thead>
              <tr>
                {detail.performance.columns.map((column) => <th scope="col">{column}</th>)}
              </tr>
            </thead>
            <tbody>
              {detail.performance.rows.map((row) => (
                <tr>
                  {row.map((cell, index) => (
                    index === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {detail.performance.caption && <p class="performance-caption">{detail.performance.caption}</p>}
      </section>
    </>
  )}

  {detail.samples?.length > 0 && (
    <script>
      document.querySelectorAll("[data-sample-tab]").forEach((tab) => {
        tab.addEventListener("click", () => {
          const index = tab.getAttribute("data-sample-tab");
          document.querySelectorAll("[data-sample-tab]").forEach((node) => {
            node.classList.toggle("is-active", node === tab);
          });
          document.querySelectorAll("[data-sample-panel]").forEach((panel) => {
            panel.hidden = panel.getAttribute("data-sample-panel") !== index;
          });
        });
      });
    </script>
  )}
</BaseLayout>
