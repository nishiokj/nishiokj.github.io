---
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
import { assetPath, formatProjectDate, linkIcon, nbsp, renderInlineBlock } from "../lib/render";
---

<BaseLayout title={site.name}>
  <header class="masthead">
    <div class="masthead-intro">
      <h1>{site.name}</h1>
      <div class="hero-meta">
        <p class="hero-title">Software Engineer</p>
        <ul class="links contact-links">
          {site.links.map((link) => {
            const external = /^https?:/i.test(link.href);
            const icon = linkIcon(link);
            return (
              <li>
                <a href={link.href} aria-label={link.label} target={external ? "_blank" : undefined} rel={external ? "noopener me" : undefined}>
                  {icon ? (
                    <>
                      <span class="contact-icon" style={`--icon: url('${icon}')`} aria-hidden="true"></span>
                      <span class="sr-only">{link.label}</span>
                    </>
                  ) : link.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
      <div class="bio">
        {site.bio.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
    <div class="hero-photo"><img src={assetPath("headshot.jpeg")} alt={site.name} width="280" height="280" /></div>
  </header>

  <hr class="rule rule--navy" />

  <section class="work" id="projects">
    <h2 class="work-heading">Projects</h2>
    {site.projectsIntro?.length > 0 && (
      <div class="projects-intro">
        {site.projectsIntro.map((paragraph) => <p set:html={renderInlineBlock(paragraph)} />)}
      </div>
    )}
    <dl class="projects">
      {site.projects.map((project) => {
        const detailHref = project.slug
          ? `/projects/${project.slug}/`
          : project.href
            ? assetPath(project.href)
            : null;
        const external = project.href && !project.slug;
        return (
          <div class="project">
            <dt class="project-title">
              <div class="project-heading-row">
                <h2>
                  {detailHref ? (
                    <a href={detailHref} target={external ? "_blank" : undefined} rel={external ? "noopener" : undefined}>
                      {project.title}
                    </a>
                  ) : project.title}
                </h2>
                <time class="project-date" datetime={project.datetime}>{nbsp(formatProjectDate(project.datetime, project.date))}</time>
              </div>
              {project.stack?.length > 0 && (
                <ul class="project-stack">
                  {project.stack.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </dt>
            <dd class="project-body">
              <p class="project-summary">
                {project.body}
                {project.slug && <a href={`/projects/${project.slug}/`} class="read-more">Technical write-up &gt;</a>}
              </p>
            </dd>
          </div>
        );
      })}
    </dl>
  </section>

  <footer class="colophon-row">
    <span class="colophon">Last updated <time datetime={site.footer.updatedDatetime}>{nbsp(site.footer.updated)}</time></span>
    <span class="colophon">{site.footer.copyright}</span>
  </footer>
</BaseLayout>
