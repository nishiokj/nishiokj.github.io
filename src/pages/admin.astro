---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Content Admin</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f1eb;
        --ink: #1b1b1f;
        --muted: #5f5a50;
        --accent: #a6342b;
        --grid: #e3dbc9;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Helvetica, Arial, sans-serif;
      }

      main {
        width: min(100%, 72rem);
        margin: 0 auto;
        padding: 2rem;
      }

      header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      h1 {
        margin: 0;
        font-family: Charter, Georgia, serif;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
      }

      .actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      button {
        border: 1px solid var(--ink);
        background: var(--ink);
        color: var(--bg);
        padding: 0.55rem 0.85rem;
        font: inherit;
        cursor: pointer;
      }

      button.secondary {
        background: transparent;
        color: var(--ink);
      }

      button:disabled {
        cursor: not-allowed;
        opacity: 0.5;
      }

      textarea {
        width: 100%;
        min-height: 72vh;
        resize: vertical;
        border: 1px solid var(--grid);
        background: #fffaf3;
        color: var(--ink);
        padding: 1rem;
        font: 0.9rem/1.5 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        tab-size: 2;
      }

      .status {
        min-height: 1.4rem;
        margin: 0.75rem 0 0;
        color: var(--muted);
      }

      .status.error {
        color: var(--accent);
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>Content Admin</h1>
        <div class="actions">
          <button class="secondary" type="button" data-reload>Reload</button>
          <button type="button" data-save disabled>Save</button>
        </div>
      </header>
      <textarea spellcheck="false" data-editor></textarea>
      <p class="status" data-status>Loading src/data/site.json...</p>
    </main>

    <script>
      const proxyUrl = "http://127.0.0.1:8082/api/v1";
      const branch = "main";
      const path = "src/data/site.json";
      const editor = document.querySelector("[data-editor]");
      const status = document.querySelector("[data-status]");
      const saveButton = document.querySelector("[data-save]");
      const reloadButton = document.querySelector("[data-reload]");

      let lastSaved = "";

      function setStatus(message, isError = false) {
        status.textContent = message;
        status.classList.toggle("error", isError);
      }

      async function proxy(action, params) {
        const response = await fetch(proxyUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action, params }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || payload.message || `Request failed: ${response.status}`);
        }
        return payload;
      }

      async function loadContent() {
        saveButton.disabled = true;
        setStatus("Loading src/data/site.json...");
        const entry = await proxy("getEntry", { branch, path });
        const parsed = JSON.parse(entry.data || "{}");
        lastSaved = `${JSON.stringify(parsed, null, 2)}\n`;
        editor.value = lastSaved;
        saveButton.disabled = false;
        setStatus("Loaded. Edit JSON, then save.");
      }

      async function saveContent() {
        let formatted;
        try {
          formatted = `${JSON.stringify(JSON.parse(editor.value), null, 2)}\n`;
        } catch (error) {
          setStatus(`Invalid JSON: ${error.message}`, true);
          return;
        }

        saveButton.disabled = true;
        setStatus("Saving...");
        await proxy("persistEntry", {
          entry: {
            slug: "site",
            path,
            raw: formatted,
          },
          assets: [],
          options: {
            collectionName: "site",
            commitMessage: "Update site content",
            status: "draft",
            useWorkflow: false,
          },
        });
        lastSaved = formatted;
        editor.value = formatted;
        saveButton.disabled = false;
        setStatus("Saved. Astro should hot-reload the site.");
      }

      editor.addEventListener("input", () => {
        saveButton.disabled = false;
        if (editor.value !== lastSaved) setStatus("Unsaved changes.");
      });
      reloadButton.addEventListener("click", () => loadContent().catch((error) => setStatus(error.message, true)));
      saveButton.addEventListener("click", () => saveContent().catch((error) => {
        saveButton.disabled = false;
        setStatus(error.message, true);
      }));

      loadContent().catch((error) => setStatus(`${error.message}. Is bun run cms running?`, true));
    </script>
  </body>
</html>
